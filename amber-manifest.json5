{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      agent_llm: { type: "string" },
      openai_api_key: { type: "string", secret: true, default: "" },
      nebius_api_key: { type: "string", secret: true, default: "" },
      gemini_api_key: { type: "string", secret: true, default: "" },
      deepseek_api_key: { type: "string", secret: true, default: "" },
    },
    required: ["agent_llm"],
    additionalProperties: false,
  },

  program: {
    image: "ghcr.io/zaidishahbaz1/tau2-purple-agentbeats:latest",
    entrypoint: ["uv", "run", "src/server.py", "--host", "0.0.0.0", "--port", "9009"],
    env: {
      AGENT_LLM: "${config.agent_llm}",
      OPENAI_API_KEY: "${config.openai_api_key}",
      NEBIUS_API_KEY: "${config.nebius_api_key}",
      GEMINI_API_KEY: "${config.gemini_api_key}",
      DEEPSEEK_API_KEY: "${config.deepseek_api_key}",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
