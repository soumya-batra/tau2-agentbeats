# Tau2 Benchmark Configuration

# Domain to evaluate: airline | retail | telecom | mock
DOMAIN=airline

# Number of tasks to run (leave empty for all tasks in the domain)
NUM_TASKS=

# Purple agent LLM (litellm format)
AGENT_LLM=openai/gpt-4o-mini

# User simulator LLM (litellm format)
USER_LLM=openai/gpt-4o-mini

# API Keys — provide whichever keys match your chosen agent_llm and user_llm
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
